{
    "$schema": "./node_modules/oxfmt/configuration_schema.json",
    "useTabs": false,
    "tabWidth": 4,
    "printWidth": 100,
    "singleQuote": false,
    "jsxSingleQuote": false,
    "quoteProps": "as-needed",
    "trailingComma": "none",
    "semi": true,
    "arrowParens": "always",
    "bracketSameLine": false,
    "bracketSpacing": true,
    "singleAttributePerLine": false,
    "ignorePatterns": [],
    "sortImports": {},
}
